[sub_resource type="GDScript" id="GDScript_waypk"]
resource_name = "Cutscene2"
script/source = "extends Control

signal textbox_closed


func _ready() -> void:
	display_text(\"You run after Denny and grab her kneck to stop her from rolling\")
	await self.textbox_closed
	$AudioStreamPlayer2D.play()
	display_text(\"Denny: WELL DONE YOUNG WARRIOIR\")
	await self.textbox_closed
	display_text(\"Denny: BACK INTO THE BOX FOR POOR OLD DENNY\")
	await self.textbox_closed
	display_text(\"Denny: OH WELL, I'LL GET OUT AGAIN ONE DAY\")
	await self.textbox_closed
	$\"UntitledArtwork7(1)3\".show()
	display_text(\"You walk to the toybox\")
	await self.textbox_closed
	$\"UntitledArtwork7(1)3/UntitledArtwork142\".show()
	display_text(\"Denny was imprisoned once more\")
	await self.textbox_closed
	$\"UntitledArtwork7(1)3\".hide()
	$UntitledArtwork8.show()
	display_text(\"You make your way back to the king's chambers\")
	await self.textbox_closed
	$UntitledArtwork8.hide()
	$UntitledArtwork9.show()
	display_text(\"Crank: I have beaten Denny, where is my next assignment\")
	await self.textbox_closed
	display_text(\"King: ...\")
	await self.textbox_closed
	display_text(\"Crank: Don't worry sir, with Jaqaveeos watching over me I'll be alright\")
	await self.textbox_closed
	$UntitledArtwork9.hide()
	display_text(\"You head over to closet and just like the king said, Rubix was there...\")
	await self.textbox_closed
	display_text(\"Watching over all of Jayqayveos land\")
	await self.textbox_closed
	$AnimationPlayer2.play(\"nut\")
	await $AnimationPlayer2.animation_finished
	get_tree().change_scene_to_file(\"res://Rubix_Cube_Battle.tscn\")
	
	
func _input(event):
	if Input.is_action_just_pressed(\"LMB a.k.a. lick my balls\") and $Label.visible:
		$Label.hide()
		emit_signal('textbox_closed')

func display_text(text) -> void:
	$Label.show()
	$AnimationPlayer.play(\"text_display\")
	$Label.text = text
"


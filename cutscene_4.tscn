[sub_resource type="GDScript" id="GDScript_2tyjd"]
resource_name = "Cutscene4"
script/source = "extends Control

signal textbox_closed


func _ready() -> void:
	display_text(\"You hoist Captain Uranium up and hold him by the arm\")
	await self.textbox_closed
	$AudioStreamPlayer2D.play()
	display_text(\"C. Uranium: I underestimated you, or perhaps I got cocky...\")
	await self.textbox_closed
	display_text(\"C. Uranium: Despite my  defeat...\")
	await self.textbox_closed
	display_text(\"C. Uranium: THE REBELION WILL LIVE ON\")
	await self.textbox_closed
	$\"UntitledArtwork7(1)3\".show()
	display_text(\"You reach the toybox for the final time\")
	await self.textbox_closed
	$\"UntitledArtwork7(1)3/UntitledArtwork142\".show()
	display_text(\"Captain Uranium gets in willingly, knowing he has been defeated\")
	await self.textbox_closed
	display_text(\"Turns out he was the last rebel\")
	await self.textbox_closed
	$\"UntitledArtwork7(1)3\".hide()
	$\"UntitledArtwork7(1)2\".show()
	display_text(\"And with that the toybox was sealed off\")
	await self.textbox_closed
	$\"UntitledArtwork7(1)2\".hide()
	$UntitledArtwork8.show()
	display_text(\"You go to meet with the king for one final time\")
	await self.textbox_closed
	$UntitledArtwork8.hide()
	$UntitledArtwork9.show()
	display_text(\"Crank: It is done sir, the final rebel has been sealed away\")
	await self.textbox_closed
	display_text(\"King: ...\")
	await self.textbox_closed
	display_text(\"Crank: It was no trouble, It was the right thing to do, stopping evil\")
	await self.textbox_closed
	display_text(\"King: ...\")
	await self.textbox_closed
	display_text(\"Crank: Thank you sir, and may Jaquaevios always be with you\")
	await self.textbox_closed
	$UntitledArtwork9.hide()
	$AnimationPlayer2.play(\"nut\")
	await $AnimationPlayer2.animation_finished
	get_tree().change_scene_to_file(\"res://win.tscn\")

	
	
func _input(event):
	if Input.is_action_just_pressed(\"LMB a.k.a. lick my balls\") and $Label.visible:
		$Label.hide()
		emit_signal('textbox_closed')

func display_text(text) -> void:
	$Label.show()
	$AnimationPlayer.play(\"text_display\")
	$Label.text = text
"

